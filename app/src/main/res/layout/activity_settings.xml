<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/accent"
            app:title="Settings"
            app:titleTextColor="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Window" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Window title" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <EditText android:id="@+id/etWindowTitle"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Floating Window" android:inputType="text" android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Default size" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <Spinner android:id="@+id/spinSize"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Default position" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <Spinner android:id="@+id/spinCorner"
                        android:layout_width="match_parent" android:layout_height="48dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Behaviour" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbAutoStart"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Auto-start on device boot"
                        android:textColor="@color/text_primary" android:textSize="14sp" />

                    <CheckBox android:id="@+id/cbSnapToEdge"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Snap to screen edge on release"
                        android:textColor="@color/text_primary" android:textSize="14sp" />

                    <CheckBox android:id="@+id/cbHighContrast"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="High contrast mode"
                        android:textColor="@color/text_primary" android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:text="Save Settings"
                android:backgroundTint="@color/accent" android:textColor="#FFFFFF" />

            <Button android:id="@+id/btnResetSettings"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:layout_marginBottom="24dp"
                android:text="Reset to Defaults"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
