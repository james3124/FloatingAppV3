<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1E1B4B"
    android:padding="24dp">

    <!-- Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="52sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvLockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Floating Window"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvLockSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enter your PIN to unlock"
        android:textSize="14sp"
        android:textColor="#A5B4FC" />

    <!-- Error -->
    <TextView
        android:id="@+id/tvLockError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#F87171"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Lockout -->
    <TextView
        android:id="@+id/tvLockout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#FCD34D"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- PIN Layout -->
    <LinearLayout
        android:id="@+id/pinLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="24dp">

        <!-- Dots -->
        <TextView
            android:id="@+id/tvPinDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ ○ ○ ○"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.3"
            android:layout_marginBottom="28dp" />

        <!-- Keypad rows -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/pin1" android:layout_width="72dp" android:layout_height="72dp" android:text="1" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin2" android:layout_width="72dp" android:layout_height="72dp" android:text="2" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin3" android:layout_width="72dp" android:layout_height="72dp" android:text="3" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" />
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/pin4" android:layout_width="72dp" android:layout_height="72dp" android:text="4" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin5" android:layout_width="72dp" android:layout_height="72dp" android:text="5" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin6" android:layout_width="72dp" android:layout_height="72dp" android:text="6" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" />
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/pin7" android:layout_width="72dp" android:layout_height="72dp" android:text="7" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin8" android:layout_width="72dp" android:layout_height="72dp" android:text="8" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin9" android:layout_width="72dp" android:layout_height="72dp" android:text="9" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" />
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <View android:layout_width="72dp" android:layout_height="72dp" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pin0" android:layout_width="72dp" android:layout_height="72dp" android:text="0" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#312E81" android:layout_marginEnd="12dp" />
            <Button android:id="@+id/pinDel" android:layout_width="72dp" android:layout_height="72dp" android:text="⌫" android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#4F46E5" />
        </LinearLayout>
    </LinearLayout>

    <!-- Pattern Layout -->
    <LinearLayout
        android:id="@+id/patternLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:visibility="gone">

        <com.floatingapp.PatternView
            android:id="@+id/patternView"
            android:layout_width="280dp"
            android:layout_height="280dp" />
    </LinearLayout>

    <!-- Biometric button -->
    <LinearLayout
        android:id="@+id/btnBiometric"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:padding="12dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="👆 Use Biometric"
            android:textSize="15sp" android:textColor="#A5B4FC" />
    </LinearLayout>

</LinearLayout>
