<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F1F5F9" />
            <corners android:bottomLeftRadius="16dp" android:bottomRightRadius="16dp" />
        </shape>
    </item>
    <item android:gravity="center" android:top="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#CBD5E1" />
            <corners android:radius="4dp" />
            <size android:width="32dp" android:height="4dp" />
        </shape>
    </item>
</layer-list>
